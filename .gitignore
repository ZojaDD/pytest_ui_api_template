# Gradle и Maven с автоматическим импортом
# При использовании Gradle или Maven с автоимпортом следует исключить файлы модулей,
# так как они будут создаваться заново, что может привести к сбоям. Раскомментируйте, если используете
# автоимпорт.
# .idea/artifacts
# .idea/compiler.xml
# .idea/jarRepositories.xml
# .idea/modules.xml
# .idea/*.iml
